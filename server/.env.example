# ═══════════════════════════════════════════════════════════════
# ServiceHub — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── MongoDB Atlas ────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/servicehub?retryWrites=true&w=majority

# ── Redis (Upstash — free tier) ──────────────────────────────────
# Get from: https://console.upstash.com
REDIS_URL=rediss://<username>:<password>@<host>.upstash.io:6380

# ── JWT Secrets (MUST be at least 32 characters!) ────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-change-this-now
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars-change-this
JWT_EXPIRES_IN=15m

# OTP / SMS (MSG91)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_msg91_otp_template_id
MSG91_OTP_LENGTH=6
MSG91_BASE_URL=https://control.msg91.com/api/v5
MSG91_TIMEOUT_MS=10000
OTP_EXPIRY_MINUTES=10
# Optional: required only if you wire non-login SMS templates through MSG91 Flow
MSG91_SMS_TEMPLATE_ID=
MSG91_BOOKING_UPDATE_TEMPLATE_ID=
DEV_OTP=123456

# ── Razorpay Payments ─────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── File Storage (Cloudinary) ─────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AWS S3 (for invoices — optional) ─────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=servicehub-invoices

# ── Commission & Pricing ──────────────────────────────────────────
DEFAULT_COMMISSION_PERCENT=20
SURGE_MULTIPLIER_MAX=2.5

# ── CORS (comma-separated production domains) ────────────────────
ALLOWED_ORIGINS=https://servicehub.vercel.app,https://yourdomain.com

# ── Sentry Error Tracking (optional but recommended) ─────────────
# Get from: https://sentry.io
SENTRY_DSN=

# ── App Metadata ──────────────────────────────────────────────────
APP_NAME=ServiceHub
SUPPORT_EMAIL=support@servicehub.in
SUPPORT_PHONE=+91XXXXXXXXXX
